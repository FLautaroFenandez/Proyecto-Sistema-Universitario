# ============================================================
# VARIABLES DE ENTORNO — PLANTILLA
# ============================================================
# Copiá este archivo como .env.local y completá los valores
# con las credenciales de tu proyecto Supabase.
#
# IMPORTANTE: .env.local NO se sube a GitHub (está en .gitignore)
# Este archivo (.env.example) SÍ se puede subir, sin valores reales.
# ============================================================

# URL del proyecto Supabase
# La encontrás en: Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública de Supabase
# La encontrás en: Dashboard → Settings → API → anon public
# Esta clave es segura para incluir en el frontend (está pensada para eso)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
